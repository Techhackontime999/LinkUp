# Django Core Settings
SECRET_KEY=your-secret-key-here-generate-with-django-get-secret-key
DEBUG=False
DJANGO_ENVIRONMENT=production

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
# Use DATABASE_URL (recommended)
# For Supabase, add ?sslmode=require at the end
DATABASE_URL=postgresql://username:password@hostname:5432/database_name
DATABASE_SSL_REQUIRE=False  # Set True for Supabase or other SSL-required databases

# Redis Configuration (for WebSockets and Caching)

# Redis Configuration (for WebSockets and Caching)
REDIS_URL=redis://localhost:6379/0

# Security Settings
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Superuser Auto-Creation (set these on Render dashboard, free-tier workaround)
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=your-strong-password

# Static and Media Files (optional, platform-dependent)
# STATIC_URL=/static/
# MEDIA_URL=/media/

# Email Configuration (optional, for error reporting)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-password
# ADMINS=Admin Name,admin@yourdomain.com

# Additional Production Settings (optional)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_AGE=86400
